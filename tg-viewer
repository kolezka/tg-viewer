# ── Functions ─────────────────────────────────────────────────────────────────
check_dependencies() {
    local missing=()
    
    # Check required scripts
    for script in "$BACKUP_SCRIPT" "$APPSTORE_DECRYPT_SCRIPT" "$POSTBOX_PARSER_SCRIPT"; do
        [[ -f "$script" ]] || missing+=("$(basename "$script")")
    done
    [[ -d "$WEBUI_SCRIPT_DIR" ]] || missing+=("apps/api/")
    
    # Check Python
    if ! command -v python3 &>/dev/null; then
        missing+=("python3")
    fi
    
    if [[ ${#missing[@]} -gt 0 ]]; then
        die "Missing dependencies: ${missing[*]}\nRun './tg-viewer setup' to install"
    fi
}

setup_dependencies() {
    title "Setting up dependencies"

    # Check Python
    if ! command -v python3 &>/dev/null; then
        die "Python 3 is required. Please install Python 3 first."
    fi

    # Install Python packages. Prefer a project-local virtualenv so PEP 668
    # (Homebrew / Linux distro externally-managed environments) doesn't block
    # the install. If a venv already exists or the user has a different
    # workflow active (e.g. conda), respect it.
    if [[ -f "$REQUIREMENTS_FILE" ]]; then
        local pip_target=("python3" "-m" "pip" "install" "-r" "$REQUIREMENTS_FILE")
        if [[ -n "${VIRTUAL_ENV:-}" || -n "${CONDA_PREFIX:-}" ]]; then
            log "Installing Python deps into active env: ${VIRTUAL_ENV:-$CONDA_PREFIX}"
            "${pip_target[@]}"
        else
            if [[ ! -d "$SCRIPT_DIR/.venv" ]]; then
                log "Creating project virtualenv at .venv/"
                python3 -m venv "$SCRIPT_DIR/.venv" || die "Could not create .venv (install python3-venv?)"
            fi
            log "Installing Python (api + tool) dependencies into .venv/"
            "$SCRIPT_DIR/.venv/bin/python" -m pip install --upgrade pip >/dev/null
            "$SCRIPT_DIR/.venv/bin/python" -m pip install -r "$REQUIREMENTS_FILE"
            ok "Python deps installed in .venv/ — activate with: source .venv/bin/activate"
        fi
    else
        warn "Requirements file not found: $REQUIREMENTS_FILE"
    fi

    # Make scripts executable
    for script in "$BACKUP_SCRIPT" "$EXTRACT_SCRIPT" "$APPSTORE_DECRYPT_SCRIPT" "$POSTBOX_PARSER_SCRIPT"; do
        if [[ -f "$script" ]]; then
            chmod +x "$script"
            log "Made executable: $(basename "$script")"
        fi
    done

    # Frontend: install Bun deps + build the production bundle, so that
    # `./tg-viewer webui` works on first run without an extra build step.
    if [[ -d "$SCRIPT_DIR/apps/web" ]]; then
        if command -v bun &>/dev/null; then
            log "Installing frontend (apps/web) dependencies..."
            (cd "$SCRIPT_DIR/apps/web" && bun install) || die "bun install failed"
            log "Building frontend bundle (apps/web/dist)..."
            (cd "$SCRIPT_DIR/apps/web" && bun run build) || die "bun run build failed"
            ok "Frontend installed and built"
        else
            warn "Bun not found — skipping frontend install. Install from https://bun.sh, then re-run setup."
            warn "(./tg-viewer webui will also auto-build on first run if Bun is available.)"
        fi
    fi

    ok "Setup complete!"
}

run_backup() {
    local dest_dir="${1:-./tg_$(date +"%Y-%m-%d_%H-%M-%S")}"
    
    title "Step 1: Backing up Telegram data"
    
    if [[ ! -f "$BACKUP_SCRIPT" ]]; then
        die "Backup script not found: $BACKUP_SCRIPT"
    fi
    
    log "Running Telegram backup to: $(_redact_path "$dest_dir")"
    "$BACKUP_SCRIPT" "$dest_dir"

    echo "$dest_dir"  # Return the backup directory (used as pipe value — do not redact)
}

# Find the inner tg_* backup directory created by tg-backup.sh
# tg-backup.sh creates $DEST/tg_$TIMESTAMP/ inside the given directory
find_inner_backup_dir() {
    local dest_dir="$1"
    # If dest_dir itself contains account-* dirs, use it directly
    if compgen -G "$dest_dir/account-*" > /dev/null 2>&1; then
        echo "$dest_dir"
        return
    fi
    # Otherwise look for the tg_* subdirectory created by tg-backup.sh
    local inner
    inner=$(find "$dest_dir" -maxdepth 1 -type d -name "tg_*" | sort | tail -1)
    if [[ -n "$inner" ]]; then
        echo "$inner"
    else
        echo "$dest_dir"
    fi
}

run_decrypt() {
    local backup_dir="$1"

    title "Step 2: Decrypting databases"

    if [[ ! -d "$backup_dir" ]]; then
        die "Backup directory not found: $backup_dir"
    fi

    local redact_arg=()
    [[ "${TG_REDACT:-0}" == "1" ]] && redact_arg=(--redact)

    log "Decrypting databases in: $(_redact_path "$backup_dir")"
    local abs_backup_dir
    abs_backup_dir="$(cd "$backup_dir" && pwd)"
    local account_arg=()
    if [[ -n "${TG_ACCOUNT_RAW:-}" ]]; then
        local resolved
        resolved=$(_resolve_account_id "$TG_ACCOUNT_RAW" "$abs_backup_dir")
        account_arg=(--account "$resolved")
        log "Account filter: $TG_ACCOUNT_RAW → account-$(_redact_path "$resolved")"
    fi
    (cd "$SCRIPT_DIR/apps" && python3 -m tool.tg_appstore_decrypt "$abs_backup_dir" "${redact_arg[@]+"${redact_arg[@]}"}" "${account_arg[@]+"${account_arg[@]}"}")
}

run_parse() {
    local backup_dir="$1"

    title "Step 3: Parsing Postbox data"

    if [[ ! -d "$backup_dir" ]]; then
        die "Backup directory not found: $backup_dir"
    fi

    local redact_arg=()
    [[ "${TG_REDACT:-0}" == "1" ]] && redact_arg=(--redact)

    log "Parsing messages, peers, and conversations in: $(_redact_path "$backup_dir")"
    local abs_backup_dir
    abs_backup_dir="$(cd "$backup_dir" && pwd)"
    local account_arg=()
    if [[ -n "${TG_ACCOUNT_RAW:-}" ]]; then
        local resolved
        resolved=$(_resolve_account_id "$TG_ACCOUNT_RAW" "$abs_backup_dir")
        account_arg=(--account "$resolved")
        log "Account filter: $TG_ACCOUNT_RAW → account-$(_redact_path "$resolved")"
    fi
    (cd "$SCRIPT_DIR/apps" && python3 -m tool.postbox_parser "$abs_backup_dir" "${redact_arg[@]+"${redact_arg[@]}"}" "${account_arg[@]+"${account_arg[@]}"}")
}

run_webui() {
    local data_dir="$1"
    local port="${2:-5000}"
    local host="${3:-127.0.0.1}"
    
    title "Step 4: Starting Web UI"
    
    if [[ ! -d "$WEBUI_SCRIPT_DIR" ]]; then
        die "Web UI package not found: $WEBUI_SCRIPT_DIR"
    fi

    if [[ ! -d "$data_dir" ]]; then
        die "Data directory not found: $data_dir"
    fi

    # Build the React frontend if it hasn't been built yet
    if [[ ! -d "$SCRIPT_DIR/apps/web/dist" ]]; then
        log "Building frontend (apps/web/dist/ not found)..."
        if ! command -v bun >/dev/null 2>&1; then
            die "bun is required but not found in PATH. Install from https://bun.sh"
        fi
        (cd "$SCRIPT_DIR/apps/web" && bun install && bun run build) || die "Frontend build failed"
    fi

    # Resolve to absolute path so the subshell `cd "$SCRIPT_DIR"` doesn't break a relative data_dir
    local abs_data_dir
    abs_data_dir="$(cd "$data_dir" && pwd)"

    log "Starting web interface..."
    log "Data directory: $(_redact_path "$abs_data_dir")"
    log "URL: http://$host:$port"

    local account_arg=()
    if [[ -n "${TG_ACCOUNT_RAW:-}" ]]; then
        local resolved
        resolved=$(_resolve_account_id "$TG_ACCOUNT_RAW" "$abs_data_dir")
        account_arg=(--account "$resolved")
        log "Account filter: $TG_ACCOUNT_RAW → account-$(_redact_path "$resolved")"
    fi
    (cd "$SCRIPT_DIR/apps" && python3 -m api "$abs_data_dir" --host "$host" --port "$port" "${account_arg[@]+"${account_arg[@]}"}")
}

run_dev() {
    local data_dir="$1"

    title "Dev stack: FastAPI (5000) + Bun (5173)"

    [[ -d "$data_dir" ]] || die "Data directory not found: $data_dir"
    [[ -d "$SCRIPT_DIR/apps/web" ]] || die "apps/web/ workspace not found at $SCRIPT_DIR/apps/web"

    if ! command -v bun >/dev/null 2>&1; then
        die "bun is required but not found in PATH. Install from https://bun.sh"
    fi

    if [[ ! -d "$SCRIPT_DIR/apps/web/node_modules" ]]; then
        log "Installing frontend dependencies..."
        (cd "$SCRIPT_DIR/apps/web" && bun install) || die "bun install failed"
    fi

    local abs_data_dir
    abs_data_dir="$(cd "$data_dir" && pwd)"

    log "FastAPI:  http://127.0.0.1:5000"
    log "Bun dev:  http://127.0.0.1:5173 (proxies API to FastAPI)"
    log "Press Ctrl+C to stop both"

    local account_arg=()
    if [[ -n "${TG_ACCOUNT_RAW:-}" ]]; then
        local resolved
        resolved=$(_resolve_account_id "$TG_ACCOUNT_RAW" "$abs_data_dir")
        account_arg=(--account "$resolved")
        log "Account filter: $TG_ACCOUNT_RAW → account-$(_redact_path "$resolved")"
    fi

    # Start FastAPI in background
    (cd "$SCRIPT_DIR/apps" && python3 -m api "$abs_data_dir" --port 5000 "${account_arg[@]+"${account_arg[@]}"}") &
    local api_pid=$!

    # Start Tailwind watcher in background
    (cd "$SCRIPT_DIR/apps/web" && bun run css:watch) &
    local css_pid=$!

    # Foreground: Bun dev server (Ctrl+C kills group)
    trap "kill $api_pid $css_pid 2>/dev/null; exit" INT TERM
    (cd "$SCRIPT_DIR/apps/web" && bun run dev)

    kill "$api_pid" "$css_pid" 2>/dev/null
}

run_clean() {
    title "Cleaning up generated data"

    local dirs_found=()

    # Collect tg_* backup directories at project root (not tg-viewer, tg-backup.sh, etc.)
    for d in "$SCRIPT_DIR"/tg_*/; do
        [[ -d "$d" ]] && dirs_found+=("$d")
    done

    if [[ ${#dirs_found[@]} -eq 0 ]]; then
        log "Nothing to clean. No tg_* backup directories found."
        return
    fi

    log "Found the following backup directories:"
    local total_size
    for d in "${dirs_found[@]}"; do
        local size
        size=$(du -sh "$d" 2>/dev/null | cut -f1)
        log "  $d ($size)"
    done
    total_size=$(du -shc "${dirs_found[@]}" 2>/dev/null | tail -1 | cut -f1)
    echo ""
    warn "This will permanently delete $total_size of data (backups, decrypted, and parsed)."
    read -rp "Continue? [y/N] " confirm
    if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
        log "Cancelled."
        return
    fi

    for d in "${dirs_found[@]}"; do
        rm -rf "$d"
        ok "Removed: $d"
    done

    ok "Cleanup complete."
}

run_ghosts() {
    local old_arg="${1:-}"
    local new_arg="${2:-}"

    title "Forensic ghost diff between two parsed snapshots"

    # Normalise either a tg_*/ root or a parsed_data/ dir to a parsed_data path.
    _resolve_parsed() {
        local p="$1"
        if [[ -d "$p/parsed_data" ]]; then
            echo "$p/parsed_data"
        elif [[ -d "$p/tg_"*/parsed_data ]]; then
            # The double-nested tg_*/tg_*/ layout that tg-backup.sh produces.
            for inner in "$p"/tg_*/parsed_data; do [[ -d "$inner" ]] && { echo "$inner"; return; }; done
        else
            echo "$p"
        fi
    }

    local old_parsed new_parsed
    if [[ -n "$old_arg" && -n "$new_arg" ]]; then
        old_parsed=$(_resolve_parsed "$old_arg")
        new_parsed=$(_resolve_parsed "$new_arg")
    else
        # Auto-pick the two newest parsed_data dirs under the script root.
        local -a found=()
        while IFS= read -r p; do found+=("$p"); done < <(
            find "$SCRIPT_DIR" -maxdepth 3 -type d -name parsed_data 2>/dev/null | \
                xargs -I {} stat -f "%m %N" {} 2>/dev/null | sort -rn | awk '{print $2}'
        )
        if (( ${#found[@]} < 2 )); then
            die "Need at least two parsed_data snapshots; found ${#found[@]}. Pass paths explicitly: $0 ghosts <old> <new>"
        fi
        new_parsed="${found[0]}"
        old_parsed="${found[1]}"
    fi

    [[ -d "$old_parsed" ]] || die "Old parsed_data not found: $old_parsed"
    [[ -d "$new_parsed" ]] || die "New parsed_data not found: $new_parsed"

    log "Old: $(_redact_path "$old_parsed")"
    log "New: $(_redact_path "$new_parsed")"

    local out="$SCRIPT_DIR/ghosts_diff.json"
    (cd "$SCRIPT_DIR/apps" && python3 -c "
import json, sys
sys.path.insert(0, '.')
from tool import ghost_detector
from pathlib import Path
result = ghost_detector.compare_snapshots(Path('$old_parsed'), Path('$new_parsed'))
with open('$out', 'w') as f:
    json.dump(result, f, indent=2, ensure_ascii=False)
print()
for acc, d in result['diffs'].items():
    print(f'  {acc}: removed={len(d[\"removed\"])}  added={len(d[\"added\"])}  modified={len(d[\"modified\"])}')
")
    ok "Diff written to: $(_redact_path "$out")"
}

run_full_workflow() {
    local dest_dir="${1:-./tg_$(date +"%Y-%m-%d_%H-%M-%S")}"
    
    echo -e "${BLUE}"
    cat << 'EOF'
  ████████╗ ██████╗       ██╗   ██╗██╗███████╗██╗    ██╗███████╗██████╔╗ 
  ╚══██╔══╝██╔════╝       ██║   ██║██║██╔════╝██║    ██║██╔════╝██╔══██╗
     ██║   ██║  ███╗█████╗ ██║   ██║██║█████╗  ██║ █╗ ██║█████╗  ██████╔╝
     ██║   ██║   ██║╚════╝ ╚██╗ ██╔╝██║██╔══╝  ██║███╗██║██╔══╝  ██╔══██╗
     ██║   ╚██████╔╝        ╚████╔╝ ██║███████╗╚███╔███╔╝███████╗██║  ██║
     ╚═╝    ╚═════╝          ╚═══╝  ╚═╝╚══════╝ ╚══╝╚══╝ ╚══════╝╚═╝  ╚═╝
EOF
    echo -e "${NC}"
    
    log "Starting complete Telegram data extraction workflow"
    log "Destination: $(_redact_path "$dest_dir")"
    echo ""
    
    # Check for Telegram running before starting
    if pgrep -x "Telegram" > /dev/null 2>&1; then
        warn "Telegram is currently running."
        warn "The postbox DB may be locked / mid-write."
        read -rp "  It's safer to quit Telegram first. Continue anyway? [y/N] " confirm
        if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
            die "Aborted. Please quit Telegram and re-run."
        fi
    fi
    
    # Step 1: Backup
    title "Step 1: Backing up Telegram data"
    log "Running Telegram backup to: $(_redact_path "$dest_dir")"

    if [[ ! -f "$BACKUP_SCRIPT" ]]; then
        die "Backup script not found: $BACKUP_SCRIPT"
    fi
    
    # Run backup script (--batch skips interactive prompts)
    "$BACKUP_SCRIPT" "$dest_dir" --batch

    # Find the actual backup dir (tg-backup.sh creates a tg_* subdir)
    backup_dir=$(find_inner_backup_dir "$dest_dir")
    log "Using backup directory: $(_redact_path "$backup_dir")"

    # Step 2: Decrypt (App Store .tempkeyEncrypted → SQLCipher)
    run_decrypt "$backup_dir"

    # Step 3: Parse (Postbox binary → messages/peers/conversations)
    run_parse "$backup_dir"

    # Step 4: Web UI
    data_dir="$backup_dir/parsed_data"
    if [[ -d "$data_dir" ]]; then
        echo ""
        ok "Workflow complete!"
        ok "Backup: $(_redact_path "$backup_dir")"
        ok "Data: $(_redact_path "$data_dir")"
        echo ""

        read -rp "Start web UI now? [Y/n] " start_ui
        if [[ "$start_ui" != "n" && "$start_ui" != "N" ]]; then
            run_webui "$data_dir"
        else
            log "To start web UI later, run: ./tg-viewer webui '$(_redact_path "$data_dir")'"
        fi
    else
        warn "Parsed data directory not found. Check output above for errors."
    fi
}

# ── Main ──────────────────────────────────────────────────────────────────────
main() {
    local port="5000"
    local host="127.0.0.1"
    local redact=false
    local positionals=()

    # Parse global options from anywhere in the arg list. Both forms work:
    #   ./tg-viewer --redact full
    #   ./tg-viewer full --redact
    local account_raw=""
    while [[ $# -gt 0 ]]; do
        case $1 in
            --port) port="$2"; shift 2 ;;
            --host) host="$2"; shift 2 ;;
            --account) account_raw="$2"; shift 2 ;;
            --redact) redact=true; shift ;;
            --help|-h) show_help; exit 0 ;;
            -*) die "Unknown option: $1" ;;
            *) positionals+=("$1"); shift ;;
        esac
    done

    if [[ "$redact" == true ]]; then
        export TG_REDACT=1
    fi
    if [[ -n "$account_raw" ]]; then
        export TG_ACCOUNT_RAW="$account_raw"
    fi

    set -- "${positionals[@]+"${positionals[@]}"}"
    local command="${1:-help}"
    
    case "$command" in
        setup)
            setup_dependencies
            ;;
        backup)
            check_dependencies
            run_backup "${2:-}"
            ;;
        decrypt)
            check_dependencies
            [[ -n "${2:-}" ]] || die "Usage: $0 decrypt <backup_dir>"
            run_decrypt "$2"
            ;;
        parse)
            check_dependencies
            [[ -n "${2:-}" ]] || die "Usage: $0 parse <backup_dir>"
            run_parse "$2"
            ;;
        webui)
            check_dependencies
            [[ -n "${2:-}" ]] || die "Usage: $0 webui <data_dir>"
            run_webui "$2" "$port" "$host"
            ;;
        dev)
            check_dependencies
            [[ -n "${2:-}" ]] || die "Usage: $0 dev <data_dir>"
            run_dev "$2"
            ;;
        full)
            check_dependencies
            run_full_workflow "${2:-}"
            ;;
        clean)
            run_clean
            ;;
        ghosts)
            check_dependencies
            run_ghosts "${2:-}" "${3:-}"
            ;;
        help|--help|-h)
            show_help
            ;;
        *)
            echo "Unknown command: $command"
            echo "Run './tg-viewer help' for usage information"
            exit 1
            ;;
    esac
}

# Run main function with all arguments
main "$@"