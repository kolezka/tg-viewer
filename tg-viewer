#!/usr/bin/env bash
# tg-viewer — Telegram Data Backup, Decrypt & Visualize CLI
# Main interface for the complete Telegram data extraction workflow

set -euo pipefail

# ── Config ────────────────────────────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BACKUP_SCRIPT="$SCRIPT_DIR/apps/tool/tg-backup.sh"
EXTRACT_SCRIPT="$SCRIPT_DIR/apps/tool/extract-keys.sh"
APPSTORE_DECRYPT_SCRIPT="$SCRIPT_DIR/apps/tool/tg_appstore_decrypt.py"
POSTBOX_PARSER_SCRIPT="$SCRIPT_DIR/apps/tool/postbox_parser.py"
WEBUI_SCRIPT_DIR="$SCRIPT_DIR/apps/api"
REQUIREMENTS_FILE="$SCRIPT_DIR/requirements.txt"

# ── Colors ────────────────────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'; BLUE='\033[0;34m'; NC='\033[0m'

log()    { echo -e "${CYAN}[INFO]${NC}  $*"; }
ok()     { echo -e "${GREEN}[OK]${NC}    $*"; }
warn()   { echo -e "${YELLOW}[WARN]${NC}  $*"; }
die()    { echo -e "${RED}[ERROR]${NC} $*" >&2; exit 1; }
title()  { echo -e "\n${BLUE}=== $* ===${NC}"; }

# Redact tg_<timestamp> segments in paths when TG_REDACT=1
_redact_path() {
    if [[ "${TG_REDACT:-0}" == "1" ]]; then
        echo "$1" | sed -E 's|tg_[0-9]{4}-[0-9]{2}-[0-9]{2}_[0-9]{2}-[0-9]{2}-[0-9]{2}|<backup>|g'
    else
        echo "$1"
    fi
}

# Resolve an --account value (peerName, bare id, or account-{id}) to a folder id
# by reading accounts-shared-data inside the given search dir. Echoes the bare id
# on success; calls die() on ambiguity / no match / missing file.
# Pure numeric ids are returned as-is without lookup.
_resolve_account_id() {
    local raw="$1" search_dir="$2"
    [[ -z "$raw" ]] && { echo ""; return; }

    local stripped="${raw#account-}"
    if [[ "$stripped" =~ ^[0-9]+$ ]]; then
        echo "$stripped"
        return
    fi

    local shared=""
    for d in "$search_dir" "$search_dir/.." "$(dirname "$search_dir")" "$(dirname "$(dirname "$search_dir")")"; do
        [[ -f "$d/accounts-shared-data" ]] && { shared="$d/accounts-shared-data"; break; }
    done
    [[ -n "$shared" ]] || die "Cannot resolve --account '$raw': accounts-shared-data not found near $search_dir"

    local output rc
    output=$(python3 - "$shared" "$raw" 2>&1 <<'PYEOF'
import json, sys
shared, query = sys.argv[1], sys.argv[2].lower()
data = json.load(open(shared))
matches = []
for acc in data.get('accounts', []):
    name = (acc.get('peerName') or '')
    if query == name.lower() or (query in name.lower() and query):
        matches.append((acc['id'] % (2**64), name))
if not matches:
    avail = ', '.join(a.get('peerName', '?') for a in data.get('accounts', []))
    sys.stderr.write(f'no match. available peerNames: {avail}\n'); sys.exit(2)
if len(matches) > 1:
    names = ', '.join(n for _, n in matches)
    sys.stderr.write(f'ambiguous: matches {names}\n'); sys.exit(3)
print(matches[0][0])
PYEOF
)
    rc=$?
    if [[ $rc -ne 0 ]]; then
        die "Cannot resolve --account '$raw': $output"
    fi
    echo "$output"
}

